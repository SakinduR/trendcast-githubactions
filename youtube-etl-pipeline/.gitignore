# =============================================================================
# .gitignore — YouTube ETL Pipeline
# =============================================================================

# Environment — NEVER commit secrets
.env
*.env
.env.local
.env.*.local

# PostgreSQL persistent data
postgres_data/

# Airflow auto-generated directories
airflow/logs/
airflow/plugins/
airflow/__pycache__/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
dist/
build/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/
jupyter/notebooks/*.csv
jupyter/notebooks/*.png

# Virtual environments
.venv/
venv/
env/
ENV/

# macOS
.DS_Store

# Docker
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# Spark checkpoints
spark-checkpoints/
/tmp/
